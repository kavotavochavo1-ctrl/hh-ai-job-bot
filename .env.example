TELEGRAM_BOT_TOKEN=replace-with-rotated-token
TELEGRAM_USER_ID=123456789
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SCORING_MODEL=deepseek/deepseek-v4-flash
HH_WEB_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 Chrome/126.0 Safari/537.36
DATABASE_URL=sqlite+aiosqlite:////data/bot.db
CANDIDATE_PROFILE_PATH=candidate_profile.md
POLL_INTERVAL_MINUTES=10
INITIAL_SYNC_DAYS=7
NOTIFICATION_THRESHOLD=70
TIMEZONE=Europe/Moscow
